# claude-trading-skills — environment variable template
#
# Copy this file to `.env` (or `.envrc` for direnv) in your downstream project
# and fill in the values. Both `.env` and `.envrc` are gitignored.
#
# Most skills also accept their key as a CLI flag (e.g. `--api-key …`), so
# setting these is optional unless you want skills to "just work" without
# threading the key through every invocation.
#
# Auto-loading in Claude Code:
#   See `docs/setup/env-loading.md` for the recommended mechanism
#   (`.claude/settings.local.json` env block). For non-Claude-Code use,
#   direnv or `set -a; source .env; set +a` both work.

# ─── Financial Modeling Prep (FMP) ─────────────────────────────────────────
# Required by ~15 skills: vcp-screener, canslim-screener, earnings-calendar,
#   economic-calendar-fetcher, earnings-trade-analyzer, pead-screener,
#   pair-trade-screener, ibd-distribution-day-monitor, ftd-detector,
#   parabolic-short-trade-planner, institutional-flow-tracker, and others.
# Free tier: 250 calls/day. Sign up: https://site.financialmodelingprep.com/
export FMP_API_KEY=""

# ─── FINVIZ Elite (optional) ───────────────────────────────────────────────
# Speeds up dividend screeners ~5-7x. Not required — skills fall back to the
# public scraper if unset.
# $39.50/month or $299.50/year. Sign up: https://elite.finviz.com/
export FINVIZ_API_KEY=""

# ─── Alpaca (only needed for portfolio-manager) ────────────────────────────
# Paper trading is free; live trading requires a funded brokerage account.
# Portfolio-manager also needs the Alpaca MCP server wired up in `.mcp.json` —
# see `.claude/skills/portfolio-manager/references/alpaca-mcp-setup.md` after
# install for the full setup.
# Sign up: https://alpaca.markets/
export ALPACA_API_KEY=""
export ALPACA_SECRET_KEY=""
export ALPACA_PAPER="true"   # "true" = paper trading, "false" = live trading

# ─── Optional: pin the cts-repo location ───────────────────────────────────
# install_cts.sh auto-discovers the cts-repo from its own location, so this
# is only needed if you keep the repo somewhere non-standard and want to
# invoke the installer via a short alias.
# export CTS_REPO="$HOME/codes/claude-trading-skills"
